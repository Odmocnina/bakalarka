<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<config>

    <models>
        <carFollowingModel>
            <id>idm</id>
        </carFollowingModel>
        <laneChangingModel>
            <id>mobil-simple</id>
        </laneChangingModel>
    </models>

    <runDetails>
        <drawCells>false</drawCells>
        <laneChange>false</laneChange>
        <timeStep>1</timeStep>
        <debug>false</debug>
        <preventCollision>false</preventCollision>
        <timeBetweenSteps>100</timeBetweenSteps>
        <drawCells>true</drawCells>
        <seed>92712587</seed>
        <logging>
            <log>true</log>
            <info>true</info>
            <warn>true</warn>
            <debug>false</debug>
            <error>true</error>
            <fatal>true</fatal>
        </logging>
        <output>
            <writeOutput>true</writeOutput>
            <file>output/output.txt</file>
            <type>txt</type>
            <csvSeparator>;</csvSeparator>
            <whatToWrite>
                <simulationDetails>true</simulationDetails>
                <simulationTime>false</simulationTime>
                <carsPassed>false</carsPassed>
                <carsOnRoad>false</carsOnRoad>
                <whenWasRoadEmpty>true</whenWasRoadEmpty>
                <laneChangesCount>true</laneChangesCount>
                <averageLaneQueueLength>true</averageLaneQueueLength>
                <averageLaneQueueLastRedLength>true</averageLaneQueueLastRedLength>
                <maxLaneQueueLength>true</maxLaneQueueLength>
                <detailedLaneQueueLength>false</detailedLaneQueueLength>
                <detailedLightPlans>false</detailedLightPlans>
                <exportDetailedToSeparateFiles>false</exportDetailedToSeparateFiles>
                <collisionCount>true</collisionCount>
                <roadDetails>true</roadDetails>
            </whatToWrite>
        </output>
    </runDetails>
</config>
